---
/*
 * Editorial page heading shared by list/index routes (Blog, Tags, Links).
 * Echoes the homepage hero's voice — a gold eyebrow tick, a large sans title
 * paired with a serif-italic accent word, and a calm subtitle — so secondary
 * pages feel designed rather than bare. An `actions` slot keeps room for page
 * controls (e.g. the Blog view switcher); the default slot drops in below.
 */
interface Props {
	// Small uppercase kicker above the title.
	eyebrow?: string;
	// Plain sans portion of the title.
	title: string;
	// Optional serif-italic accent word rendered after the title.
	accent?: string;
	// Calm one-line description under the title.
	subtitle?: string;
}

const { eyebrow, title, accent, subtitle } = Astro.props as Props;
---

<header class="section-enter relative overflow-hidden border-[3px] border-[var(--mihn-line)] bg-[var(--mihn-card)] p-5 shadow-[var(--mihn-shadow)] md:p-7">
	<div class="pointer-events-none absolute -right-10 top-5 rotate-[24deg] border-y-[3px] border-black bg-[var(--mihn-yellow)] px-16 py-1 font-mono text-[11px] font-black uppercase tracking-[0.2em] text-black">
		MIHN INDEX
	</div>
	<div class="flex flex-wrap items-end justify-between gap-x-6 gap-y-4">
		<div class="min-w-0">
			{eyebrow && (
				<p class="mb-3 flex w-fit items-center gap-2 border-[3px] border-[var(--mihn-line)] bg-[var(--mihn-green)] px-2.5 py-1 font-mono text-[11px] font-black uppercase tracking-[0.18em] text-black shadow-[3px_3px_0_var(--mihn-line)]">
					<span class="h-2 w-2 bg-black"></span>
					{eyebrow}
				</p>
			)}
			<h1
				class="flex flex-wrap items-baseline gap-x-3 gap-y-1 font-sans text-[3rem] font-black uppercase italic leading-[0.82] tracking-normal text-[var(--mihn-ink)] md:text-[5.6rem]"
				transition:name="page-title"
				transition:animate="fade"
			>
				<span class="font-sans">{title}</span>
				{accent && (
					<span class="font-sans text-[0.78em] text-[var(--mihn-orange)]">{accent}</span>
				)}
			</h1>
			{subtitle && (
				<p class="mt-4 max-w-xl border-l-[6px] border-[var(--mihn-orange)] bg-white/60 px-3 py-2 font-mono text-[13px] font-bold uppercase leading-7 text-[var(--mihn-ink)] dark:bg-black/20">{subtitle}</p>
			)}
		</div>
		<div class="shrink-0">
			<slot name="actions" />
		</div>
	</div>
	<slot />
</header>
