---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MobileDrawer from '../components/MobileDrawer.astro';
import PostCard from '../components/PostCard.astro';
import { BILIBILI_URL, CREATINF_URL, GITHUB_URL, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const BASE = import.meta.env.BASE_URL;
// Keep home preview aligned with list pagination size for consistent editorial cadence.
const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);

const HOME_WALLPAPER = 'https://img.danarnoux.com/misc/home-2rd1yuubn4hc1.webp';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} - Research, Engineering & Technical Notes`} description="A personal blog about research, engineering workflows, and reproducible long-form writing.涵盖编程、技术笔记和工程实践。" />
	</head>
	<body>
		<Header />
		<MobileDrawer />
		<main class="page-shell page-fade-in pb-12 pt-16 md:pb-16 md:pt-20" transition:name="page-main" transition:animate="fade">
			<div class="space-y-9">
				<section class="mihn-hero hero-enter min-h-[520px] md:min-h-[610px]">
					<div class="absolute inset-0">
						<img
							src={HOME_WALLPAPER}
							alt="Homepage wallpaper"
							class="mihn-hero-image hero-kenburns h-full w-full object-cover object-[74%_center] md:object-center"
						/>
						<div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(0,0,0,0.82),rgba(0,0,0,0.34)_48%,rgba(0,0,0,0.64))]"></div>
					</div>
					<div class="mihn-label-cloud top" aria-hidden="true">
						<span class="mihn-sticker warn" style="--r:-3deg">NO.129251743</span>
						<span class="mihn-sticker cyan" style="--r:2deg">VHS LOG</span>
						<span class="mihn-sticker hot" style="--r:-1deg">ERROR-FREE?</span>
					</div>
					<div class="mihn-label-cloud right" aria-hidden="true">
						<span class="mihn-sticker" style="--r:3deg">RSS FEED</span>
						<span class="mihn-sticker warn" style="--r:-2deg">BLOG WALL</span>
						<span class="mihn-sticker cyan" style="--r:1deg">MIHN.CC.CD</span>
					</div>
					<div class="mihn-hero-copy">
						<span class="mihn-kicker">New Eridu Signal</span>
						<h1 class="mihn-title" data-glitch="靡虹 MiHN" transition:name="page-title" transition:animate="fade">
							靡虹 MiHN
						</h1>
						<p class="mt-5 max-w-2xl border-l-[6px] border-[var(--mihn-yellow)] bg-black/58 px-4 py-3 font-mono text-sm font-bold uppercase leading-7 text-[#fff8df] backdrop-blur-sm md:text-base">
							{SITE_DESCRIPTION} / engineering notes / code fragments / city-feed archive
						</p>
						<div class="mt-5 flex flex-wrap gap-2">
							<span class="mihn-sticker warn" style="--r:-2deg">Research</span>
							<span class="mihn-sticker cyan" style="--r:1deg">Engineering</span>
							<span class="mihn-sticker hot" style="--r:2deg">Notes</span>
						</div>
						<div class="mt-6 flex items-center gap-3">
							<a
								href={GITHUB_URL}
								target="_blank"
								rel="noreferrer"
								class="icon-button inline-flex h-11 w-11 items-center justify-center border-[3px] border-black bg-[var(--mihn-yellow)] text-black shadow-[4px_4px_0_#111] transition-transform hover:-translate-y-1"
								aria-label="GitHub"
							>
								<svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
									<path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.523 2 12 2z" />
								</svg>
								<span class="sr-only">GitHub</span>
							</a>
							<a
								href={BILIBILI_URL}
								target="_blank"
								rel="noreferrer"
								class="icon-button inline-flex h-11 w-11 items-center justify-center border-[3px] border-black bg-[var(--mihn-cyan)] text-black shadow-[4px_4px_0_#111] transition-transform hover:-translate-y-1"
								aria-label="Bilibili"
							>
								<svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
									<path d="M7.4 2.8a1 1 0 0 1 1.4 0L12 6l3.2-3.2a1 1 0 1 1 1.4 1.4L14.5 6.3h3.8A3.7 3.7 0 0 1 22 10v8.3A3.7 3.7 0 0 1 18.3 22H5.7A3.7 3.7 0 0 1 2 18.3V10a3.7 3.7 0 0 1 3.7-3.7h3.8L7.4 4.2a1 1 0 0 1 0-1.4ZM5.7 8.3A1.7 1.7 0 0 0 4 10v8.3c0 .9.8 1.7 1.7 1.7h12.6c.9 0 1.7-.8 1.7-1.7V10c0-.9-.8-1.7-1.7-1.7H5.7Zm1.8 3a1 1 0 0 1 1 1v3.4a1 1 0 1 1-2 0v-3.4a1 1 0 0 1 1-1Zm9 0a1 1 0 0 1 1 1v3.4a1 1 0 1 1-2 0v-3.4a1 1 0 0 1 1-1Z" />
								</svg>
								<span class="sr-only">Bilibili</span>
							</a>
							<a
								href={CREATINF_URL}
								target="_blank"
								rel="noreferrer"
								class="icon-button inline-flex h-11 w-11 items-center justify-center border-[3px] border-black bg-[var(--mihn-magenta)] text-black shadow-[4px_4px_0_#111] transition-transform hover:-translate-y-1"
								aria-label="CreatInf"
							>
								<span class="text-lg font-semibold leading-none">∞</span>
								<span class="sr-only">CreatInf</span>
							</a>
						</div>
					</div>
				</section>

				<!-- Decorative pop-art ribbon spanning the full hero row width. -->
				<section class="hero-enter hero-enter-delay-2 -mt-2" aria-hidden="true">
					<div class="dots-band" data-dots-band>
						<canvas></canvas>
					</div>
				</section>
			</div>

			<section class="mt-10">
				<div class="mb-4 flex items-center justify-between" data-reveal>
					<h2 class="mihn-section-title">Latest Posts</h2>
					<a
						href={`${BASE}blog/`}
						class="apple-float-chip inline-flex items-center gap-1.5 px-3 py-2 text-sm no-underline"
					>
						<span class="apple-float-label">
							<span>View all</span>
							<svg viewBox="0 0 20 20" class="h-4 w-4 opacity-75" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
								<path d="M4.75 10h10.5" stroke-linecap="round" />
								<path d="M10.75 5.5 15.25 10l-4.5 4.5" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</span>
					</a>
				</div>
				<ul class="grid gap-4 md:grid-cols-2">
					{
						posts.map((post, idx) => (
							<li class="relative" data-reveal style={`--reveal-delay: ${(idx % 2) * 80}ms`}>
								<PostCard
									post={post}
									base={BASE}
									titleTag="h3"
									maxMobile={3}
									maxDesktop={3}
									reloadOnNavigate={true}
								/>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />

		<script is:inline>
			(() => {
				/*
				 * Pop-art dot ribbon: a drifting halftone wave on <canvas>.
				 * Gold dots with sparse blue accents and hollow rings; brightness and
				 * size follow two layered sine waves so the band reads as a slow,
				 * left-to-right current with twinkling crests.
				 * Pauses off-screen / in hidden tabs; reduced motion gets one static frame.
				 */
				const initDotsBand = () => {
					const wrap = document.querySelector('[data-dots-band]');
					if (!wrap || wrap.dataset.bound === 'true') return;
					wrap.dataset.bound = 'true';

					const canvas = wrap.querySelector('canvas');
					const ctx = canvas?.getContext('2d');
					if (!ctx) return;

					const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
					const SPACING = 17;
					const ROWS = 3;

					let width = 0;
					let height = 0;
					let dots = [];

					const build = () => {
						const dpr = Math.min(window.devicePixelRatio || 1, 2);
						const rect = wrap.getBoundingClientRect();
						width = rect.width;
						height = rect.height;
						canvas.width = Math.max(1, Math.round(width * dpr));
						canvas.height = Math.max(1, Math.round(height * dpr));
						ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

						dots = [];
						const cols = Math.ceil(width / SPACING) + 1;
						for (let c = 0; c < cols; c++) {
							for (let r = 0; r < ROWS; r++) {
								dots.push({
									x: c * SPACING,
									row: r,
									phase: Math.random() * Math.PI * 2,
									twinkle: 0.6 + Math.random() * 0.9,
									accent: Math.random() < 0.055,
									ring: Math.random() < 0.075,
								});
							}
						}
					};

					let t = Math.random() * 100;
					let rafId = 0;
					let running = false;

					const draw = () => {
						ctx.clearRect(0, 0, width, height);
						const dark = document.documentElement.classList.contains('dark');
						const base = dark ? '226, 190, 110' : '170, 118, 32';
						const accent = dark ? '96, 165, 250' : '37, 99, 235';
						const rowGap = height / (ROWS + 1);

						for (const d of dots) {
							// Primary wave travels right; the slower secondary wave breaks uniformity.
							const wave = Math.sin(d.x * 0.018 - t * 1.55 + d.row * 0.85);
							const drift = Math.sin(d.x * 0.0065 + t * 0.6 + d.phase);
							const y = rowGap * (d.row + 1) + wave * 7 + drift * 3;
							const crest = (wave + 1) / 2;
							const pulse = (Math.sin(t * d.twinkle * 2 + d.phase) + 1) / 2;
							const alpha = 0.07 + crest * 0.3 + pulse * 0.22 * crest;
							const radius = 1.05 + crest * 1.25 + pulse * 0.65;
							const rgb = d.accent ? accent : base;

							if (d.ring) {
								ctx.strokeStyle = `rgba(${rgb}, ${Math.min(alpha * 1.15, 0.6)})`;
								ctx.lineWidth = 1;
								ctx.beginPath();
								ctx.arc(d.x, y, radius + 1.4, 0, Math.PI * 2);
								ctx.stroke();
							} else {
								ctx.fillStyle = `rgba(${rgb}, ${alpha})`;
								ctx.beginPath();
								ctx.arc(d.x, y, radius, 0, Math.PI * 2);
								ctx.fill();
							}
						}
					};

					const tick = () => {
						t += 0.016;
						draw();
						rafId = requestAnimationFrame(tick);
					};

					let destroyed = false;
					let inView = true;
					const start = () => {
						if (running || destroyed || reducedMotion) return;
						running = true;
						rafId = requestAnimationFrame(tick);
					};
					const stop = () => {
						running = false;
						if (rafId) cancelAnimationFrame(rafId);
						rafId = 0;
					};

					let resizeRaf = 0;
					let io = null;
					const onVisibility = () => {
						if (document.hidden || !inView) stop();
						else start();
					};
					const onResize = () => {
						if (resizeRaf) return;
						resizeRaf = requestAnimationFrame(() => {
							resizeRaf = 0;
							build();
							draw();
						});
					};

					// Full teardown so route swaps and tab switches can never revive a
					// loop that draws to a detached canvas.
					const destroy = () => {
						destroyed = true;
						stop();
						if (resizeRaf) cancelAnimationFrame(resizeRaf);
						resizeRaf = 0;
						if (io) io.disconnect();
						document.removeEventListener('visibilitychange', onVisibility);
						window.removeEventListener('resize', onResize);
						document.removeEventListener('astro:before-swap', destroy);
					};

					// Replace any instance left over from a previous route.
					if (typeof window.__dotsBandDestroy === 'function') window.__dotsBandDestroy();
					window.__dotsBandDestroy = destroy;

					build();
					draw();

					if (!reducedMotion) {
						io = new IntersectionObserver((entries) => {
							for (const entry of entries) {
								inView = entry.isIntersecting;
								if (inView && !document.hidden) start();
								else stop();
							}
						});
						io.observe(wrap);
						document.addEventListener('visibilitychange', onVisibility);
					}

					window.addEventListener('resize', onResize);
					document.addEventListener('astro:before-swap', destroy);
				};

				// Keep exactly one document-level page-load hook no matter how many times
				// this inline script re-executes across View Transition navigations.
				window.__dotsBandInit = initDotsBand;
				if (!window.__dotsBandPageLoadBound) {
					window.__dotsBandPageLoadBound = true;
					document.addEventListener('astro:page-load', () => {
						if (typeof window.__dotsBandInit === 'function') window.__dotsBandInit();
					});
				}
				initDotsBand();
			})();
		</script>
	</body>
</html>
